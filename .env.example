# Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# APPLICATION
# ============================================================
APP_NAME=AI Data Platform
APP_ENV=development
APP_VERSION=1.0.0
SECRET_KEY=your-super-secret-key-change-in-production
DEBUG=true

# ============================================================
# DATABASES
# ============================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ai_platform
POSTGRES_USER=platform_user
POSTGRES_PASSWORD=platform_pass

MONGODB_URI=mongodb://localhost:27017/ai_platform
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

# ============================================================
# AI / LLM
# ============================================================
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo-preview
ANTHROPIC_API_KEY=your-anthropic-key
HUGGINGFACE_TOKEN=your-hf-token

# Vector DB
CHROMADB_HOST=localhost
CHROMADB_PORT=8100

# ============================================================
# MESSAGING
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================================
# AUTH (.NET Services)
# ============================================================
JWT_SECRET=your-jwt-secret-key-min-32-chars
JWT_ISSUER=ai-platform
JWT_AUDIENCE=ai-platform-clients
JWT_EXPIRY_MINUTES=60
REFRESH_TOKEN_EXPIRY_DAYS=7

# OAuth2
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# ============================================================
# CLOUD STORAGE
# ============================================================
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=ai-platform-data

AZURE_STORAGE_CONNECTION_STRING=your-azure-connection-string
AZURE_BLOB_CONTAINER=ai-platform-data

GCP_PROJECT_ID=your-gcp-project
GCP_CREDENTIALS_PATH=/secrets/gcp-credentials.json

# ============================================================
# NOTIFICATIONS
# ============================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@ai-platform.com

SLACK_BOT_TOKEN=xoxb-your-slack-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx

TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/xxx

# ============================================================
# OBSERVABILITY
# ============================================================
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
PROMETHEUS_PORT=9090

# ============================================================
# SERVICES PORTS
# ============================================================
GATEWAY_PORT=8000
INGESTION_PORT=8001
VALIDATION_PORT=8002
TRANSFORMATION_PORT=8003
AI_SERVICE_PORT=8004
PDF_SERVICE_PORT=8005
SCHEDULING_PORT=8006
NOTIFICATION_PORT=8007
ANALYTICS_PORT=8008
AUTH_PORT=8010
USER_SERVICE_PORT=8011
REPORTING_PORT=8012

# ============================================================
# FEATURE FLAGS
# ============================================================
ENABLE_AI_FEATURES=true
ENABLE_OCR=true
ENABLE_STREAMING=true
ENABLE_MULTI_TENANT=true
ENABLE_AUDIT_LOG=true
